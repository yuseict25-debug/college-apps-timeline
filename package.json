{
  "name": "apex-timeline",
  "version": "1.0.0",
  "private": true,
  "description": "STEM portfolio timeline tracker with Firebase cloud sync",
  "scripts": {
    "build": "node scripts/generate-firebase-config.js",
    "vercel-build": "node scripts/generate-firebase-config.js",
    "setup": "bash scripts/setup-cloud.sh",
    "setup:resume": "bash scripts/setup-resume.sh",
    "deploy:rules": "firebase deploy --only firestore:rules",
    "deploy:vercel": "vercel deploy --prod --yes",
    "deploy:vercel:env": "node scripts/push-vercel-env.js"
  },
  "devDependencies": {
    "firebase-tools": "^13.35.1",
    "vercel": "^54.15.0"
  }
}
